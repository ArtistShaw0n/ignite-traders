# Copy this file to `.env.local` and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Public site URL (used for sitemap, robots, canonical tags, JSON-LD)
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# Auth.js admin session secret (REQUIRED). Generate: openssl rand -base64 33
# Use a unique value per environment (local / Preview / Production).
AUTH_SECRET=

# Admin DB connection (Neon) is pulled via `vercel env pull`. The first admin
# login is created with: npx tsx db/create-admin-user.ts <email> <password>

# WhatsApp / contact (optional)
# NEXT_PUBLIC_WHATSAPP_NUMBER=+8801XXXXXXXXX
# NEXT_PUBLIC_CONTACT_EMAIL=info@example.com
