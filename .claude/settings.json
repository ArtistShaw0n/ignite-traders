{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Read",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(npm run:*)",
      "Bash(npx prettier:*)",
      "Bash(npx tsx:*)",
      "Bash(vercel ls:*)",
      "Bash(vercel env ls:*)",
      "Bash(curl:*)"
    ]
  }
}
